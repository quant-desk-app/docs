{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "luma",
  "name": "QuantDesk Docs",
  "colors": {
    "primary": "#8fbf1f",
    "light": "#b7ff2a",
    "dark": "#b7ff2a"
  },
  "favicon": "/logo.svg",
  "appearance": {
    "default": "system"
  },
  "styling": {
    "codeblocks": {
      "theme": {
        "light": "github-light",
        "dark": "dracula"
      }
    }
  },
  "redirects": [
    {
      "source": "/docs/community/contributing",
      "destination": "/docs/developers/submit-strategy-example"
    }
  ],
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "/docs/faq"
      },
      {
        "type": "github",
        "href": "https://github.com/quant-desk-app/quantdesk-sdk"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Launch App",
      "href": "https://quantdesk.app"
    }
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "App",
          "icon": "rocket",
          "href": "https://quantdesk.app"
        },
        {
          "anchor": "SDK",
          "icon": "code",
          "href": "https://github.com/quant-desk-app/quantdesk-sdk"
        },
        {
          "anchor": "Contributing",
          "icon": "hand-wave",
          "href": "/docs/developers/submit-strategy-example"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Product & guides",
            "pages": [
              {
                "group": "Overview",
                "icon": "compass",
                "pages": [
                  "docs/intro",
                  "docs/overview/sdk-architecture-tour",
                  "docs/overview/what-is-quantdesk",
                  "docs/overview/unified-portfolio",
                  "docs/overview/features-and-tools",
                  "docs/overview/visual-product-tour",
                  "docs/overview/why-quantdesk",
                  "docs/overview/uniques-and-roadmap",
                  "docs/overview/docs-philosophy"
                ]
              },
              {
                "group": "Getting started",
                "icon": "rocket",
                "expanded": true,
                "pages": [
                  "docs/getting-started/start-trading-in-5-minutes"
                ]
              },
              {
                "group": "Trading Terminal",
                "icon": "chart-line",
                "expanded": false,
                "pages": [
                  "docs/trading/overview",
                  "docs/trading/perp-market-coverage",
                  "docs/trading/lite-vs-pro",
                  "docs/trading/order-entry",
                  "docs/trading/order-book",
                  "docs/trading/terminal-shortcuts"
                ]
              },
              {
                "group": "Data Plane",
                "icon": "database",
                "expanded": false,
                "pages": [
                  "docs/data/overview",
                  "docs/data/data-sources",
                  "docs/data/refresh-rates"
                ]
              },
              {
                "group": "Social Surfaces",
                "icon": "users",
                "expanded": false,
                "pages": [
                  "docs/social/overview",
                  "docs/social/verified-flex-charter",
                  "docs/social/proof-badges",
                  "docs/social/x-stream",
                  "docs/social/copy-trading",
                  "docs/social/strategy-collaboration"
                ]
              },
              {
                "group": "Security and trust",
                "icon": "shield-check",
                "expanded": false,
                "pages": [
                  "docs/security/overview",
                  "docs/security/protocol-and-fairness",
                  "docs/security/fees-and-fairness"
                ]
              },
              {
                "group": "FAQ",
                "icon": "circle-question",
                "expanded": true,
                "pages": [
                  "docs/faq/index",
                  "docs/faq/wallet-and-network",
                  "docs/faq/orders-risk-and-fees"
                ]
              }
            ]
          }
        ]
      },
      {
        "tab": "Developers",
        "groups": [
          {
            "group": "SDK & APIs",
            "icon": "code",
            "expanded": true,
            "pages": [
              "docs/developers/quickstart",
              "docs/developers/portfolio-parsing",
              "docs/developers/building-on-quantdesk",
              "docs/developers/submit-strategy-example",
              "docs/developers/authentication",
              "docs/developers/api-overview",
              "docs/developers/websocket-overview",
              "docs/developers/errors-and-rate-limits"
            ]
          }
        ]
      },
      {
        "tab": "Resources",
        "groups": [
          {
            "group": "Changelog",
            "icon": "clock-rotate-left",
            "expanded": true,
            "pages": [
              "docs/changelog/2026-07-13",
              "docs/changelog/2026-07-06",
              "docs/changelog/2026-06-29",
              "docs/changelog/2026-06-26",
              "docs/changelog/2026-06-24",
              "docs/changelog/2026-06-23",
              "docs/changelog/2026-06-22",
              "docs/changelog/2026-06-15",
              "docs/changelog/2026-06-08",
              "docs/changelog/2026-06-05",
              "docs/changelog/2026-06-01",
              "docs/changelog/2026-05-30"
            ]
          }
        ]
      }
    ]
  }
}
