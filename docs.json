{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "luma",
  "name": "QuantDesk Docs",
  "colors": {
    "primary": "#8fbf1f",
    "light": "#b7ff2a",
    "dark": "#b7ff2a"
  },
  "favicon": "/logo.svg",
  "appearance": {
    "default": "system"
  },
  "styling": {
    "codeblocks": {
      "theme": {
        "light": "github-light",
        "dark": "dracula"
      }
    }
